<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mi Campo Survey Email</title>
    <style type="text/css">
      body {
        margin: 0;
        padding: 0;
        background-color: #eee9dd;
      }

      table {
        border-collapse: collapse;
      }

      img {
        border: 0;
        display: block;
        outline: none;
        text-decoration: none;
      }

      .mi-container {
        width: 680px;
      }

      .hero-bg {
        background-color: #171716;
      }

      .hero-left {
        height: 386px;
        overflow: hidden;
        position: relative;
        width: 88px;
      }

      .hero-tequila {
        color: #f3282e;
        font-family: Impact, Arial Black, Arial, sans-serif;
        font-size: 26px;
        left: 2px;
        line-height: 28px;
        position: absolute;
        text-transform: uppercase;
        /* top: 2px; */
      }

      .hero-micampo {
        color: #f3282e;
        font-family: Impact, Arial Black, Arial, sans-serif;
        font-size: 78px;
        left: 95px;
        letter-spacing: 1px;
        line-height: 78px;
        position: absolute;
        text-transform: uppercase;
        top: 35px;
        transform: rotate(90deg) scaleY(1.32) scaleX(1.1);

        transform-origin: left top;
        white-space: nowrap;
      }

      .hero-legal {
        color: #ffffff;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 9px;
        line-height: 12px;
        padding-top: 23px;
        text-align: center;
      }

      .hero-title {
        color: #f4f0e6;
        font-family: Impact, Arial Black, Arial, sans-serif;
        font-size: 66px;
        line-height: 70px;
        padding-top: 58px;
        text-align: center;
        text-transform: uppercase;
      }

      .hero-title-text {
        display: inline-block;
        transform: scaleX(0.86) scaleY(1.16);
        transform-origin: center;
      }

      .hero-divider {
        padding-top: 10px;
        text-align: center;
      }

      .hero-divider img {
        display: inline-block;
        height: auto;
        width: 72px;
      }

      .hero-subtitle {
        color: #ffffff;
        font-family: Arial Narrow, Arial, Helvetica, sans-serif;
        font-size: 26px;
        font-stretch: condensed;
        line-height: 30px;
        padding-top: 15px;
        text-align: center;
        text-transform: uppercase;
      }

      .hero-gift {
        color: #ffffff;
        font-family: Impact, Arial Black, Arial, sans-serif;
        font-size: 18px;
        line-height: 22px;
        padding-top: 15px;
        text-align: center;
        text-transform: uppercase;
      }

      .hero-right-img {
        height: 386px;
        object-fit: cover;
        object-position: left top;
        width: 190px;
      }

      .section-2 {
        background-color: #f4f1e2;
        color: #050505;
        font-family: Arial, Helvetica, sans-serif;
      }

      .section-2-inner {
        padding: 64px 46px 74px;
        text-align: center;
      }

      .section-2-greeting {
        color: #050505;
        font-size: 20px;
        font-weight: 400;
        letter-spacing: 0;
        line-height: 26px;
        text-transform: uppercase;
      }

      .section-2-divider {
        padding-top: 22px;
        text-align: center;
      }

      .section-2-divider img {
        display: inline-block;
        filter: brightness(0) saturate(100%) invert(54%) sepia(93%) saturate(553%) hue-rotate(141deg) brightness(88%) contrast(91%);
        height: auto;
        width: 100px;
      }

      .section-2-copy {
        color: #050505;
        font-size: 16px;
        line-height: 28px;
        padding-top: 30px;
        text-align: center;
      }

      .mi-red {
        color: #f3282e;
        font-weight: 700;
      }

      .section-2-banner-wrap {
        padding-top: 56px;
        position: relative;
        text-align: center;
      }

      .section-2-banner-frame {
        display: inline-block;
        line-height: 0;
        position: relative;
      }

      .section-2-placeholder {
        background-color: #ebe8da;
        color: rgba(160, 157, 144, 0.34);
        font-family: Arial, Helvetica, sans-serif;
        font-size: 8px;
        font-weight: 700;
        height: 347px;
        line-height: 10px;
        overflow: hidden;
        padding-top: 2px;
        position: absolute;
        right: -112px;
        top: 34px;
        width: 430px;
        z-index: 0;
      }

      .section-2-placeholder-row {
        display: block;
        height: 10px;
        line-height: 10px;
        white-space: nowrap;
      }

      .section-2-banner-frame:before {
        background-color: #19a7b7;
        content: "";
        height: 17px;
        left: -16px;
        position: absolute;
        top: -17px;
        width: 456px;
        z-index: 1;
      }

      .section-2-banner-frame:after {
        background-color: #f3282e;
        bottom: -17px;
        content: "";
        height: 17px;
        position: absolute;
        right: -16px;
        width: 456px;
        z-index: 1;
      }

      .section-2-banner {
        display: block;
        height: auto;
        position: relative;
        width: 456px;
        z-index: 2;
      }

      .section-3 {
        background-color: #f4f1e2;
        color: #171716;
        font-family: Arial, Helvetica, sans-serif;
      }

      .section-3-banner {
        background-color: #f3282e;
        background-image: linear-gradient(90deg, #f3282e 0, #f3282e 40%, #df171c 40%, #df171c 100%);
        color: #171716;
        height: 238px;
        overflow: hidden;
        position: relative;
      }

      .section-3-banner:before,
      .section-3-banner:after {
        background-image: radial-gradient(circle at 8px 8px, #171716 0 7px, transparent 8px);
        background-size: 16px 16px;
        content: "";
        height: 16px;
        left: 0;
        position: absolute;
        width: 100%;
        z-index: 2;
      }

      .section-3-banner:before {
        top: -8px;
      }

      .section-3-banner:after {
        bottom: -8px;
      }

      .section-3-texture {
        background-image: repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.06) 0 1px, transparent 1px 7px);
        height: 100%;
        left: 40%;
        opacity: 0.5;
        position: absolute;
        top: 0;
        width: 60%;
      }

      .section-3-copy-wrap {
        left: 178px;
        position: absolute;
        top: 56px;
        width: 500px;
        z-index: 3;
      }

      .section-3-please {
        color: #171716;
        font-family: Impact, Arial Black, Arial, sans-serif;
        font-size: 36px;
        line-height: 36px;
        text-transform: uppercase;
        transform: scaleY(1.2) scaleX(0.95);
      }

      .section-3-main {
        color: #f4f1e2;
        font-family: Impact, Arial Black, Arial, sans-serif;
        font-size: 36px;
        line-height: 42px;
        text-transform: uppercase;
        transform: scaleY(1.2) scaleX(0.95);
      }

      .section-3-thanks {
        color: #171716;
        font-family: Impact, Arial Black, Arial, sans-serif;
        font-size: 30px;
        line-height: 34px;
        text-transform: uppercase;
        transform: scaleY(1.2) scaleX(0.95);
      }

      @media screen and (max-width: 480px) {
        .mi-container {
          width: 100% !important;
        }

        .section-2-inner {
          padding-left: 22px !important;
          padding-right: 22px !important;
        }

        .section-2-banner,
        .section-2-banner-frame:before,
        .section-2-banner-frame:after {
          width: 100% !important;
        }
      }
    </style>
  </head>
  <body>
    <table width="100%" border="0" cellspacing="0" cellpadding="0" role="presentation">
      <tr>
        <td align="center" style="padding:12px 0;background-color:#eee9dd;">
          <table class="mi-container" width="680" border="0" cellspacing="0" cellpadding="0" role="presentation">
            %%=CONTENTBLOCKBYNAME("MiCampoHero")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoSection2")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoSection3")=%%
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
