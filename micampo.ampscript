<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mi Campo Survey Email</title>
    <style type="text/css">
      body {
        margin: 0;
        padding: 0;
        background-color: #eee9dd;
        font-family: Helvetica, Arial, sans-serif;
      }

      table {
        border-collapse: collapse;
        font-family: Helvetica, Arial, sans-serif;
      }

      img {
        border: 0;
        display: block;
        outline: none;
        text-decoration: none;
      }

      .mi-container {
        width: 680px;
      }

      .browser-link {
        background-color: #f4f1e2;
        color: #000000;
        font-family: Helvetica, Arial, sans-serif;
        font-size: 16px;
        line-height: 20px;
        padding: 18px 20px 20px;
        text-align: center;
      }

      .browser-link a {
        color: #000000;
        text-decoration: underline;
      }

      .hero-bg {
        background-color: #171716;
      }

      .hero-left {
        height: 386px;
        overflow: hidden;
        position: relative;
        width: 132px;
      }

      .hero-left-img {
        display: block;
        height: 386px;
        width: 90px;
      }

      .hero-tequila {
        color: #f3282e;
        font-family: "Champion HTF Featherweight", "Champion-HTF-Featherweight", Impact, "Arial Narrow", Helvetica, sans-serif;
        font-size: 26px;
        left: 2px;
        line-height: 28px;
        position: absolute;
        text-transform: uppercase;
        /* top: 2px; */
      }

      .hero-micampo {
        color: #f3282e;
        font-family: "Champion HTF Featherweight", "Champion-HTF-Featherweight", Impact, "Arial Narrow", Helvetica, sans-serif;
        font-size: 78px;
        left: 95px;
        letter-spacing: 1px;
        line-height: 78px;
        position: absolute;
        text-transform: uppercase;
        top: 35px;
        transform: rotate(90deg) scaleY(1.32) scaleX(1.1);

        transform-origin: left top;
        white-space: nowrap;
      }

      .hero-legal {
        color: #ffffff;
        font-family: Helvetica, Arial, sans-serif;
        font-size: 9px;
        line-height: 12px;
        padding-top: 23px;
        text-align: center;
      }

      .hero-title {
        color: #f4f0e6;
        font-family: "Champion HTF Featherweight", "Champion-HTF-Featherweight", Impact, "Arial Narrow", Helvetica, sans-serif;
        font-size: 66px;
        line-height: 70px;
        padding-top: 58px;
        text-align: center;
        text-transform: uppercase;
      }

      .hero-title-text {
        display: inline-block;
        transform: scaleX(0.86) scaleY(1.16);
        transform-origin: center;
      }

      .hero-divider {
        padding-top: 10px;
        text-align: center;
      }

      .hero-divider img {
        display: inline-block;
        height: auto;
        width: 72px;
      }

      .hero-subtitle {
        color: #ffffff;
        font-family: Helvetica, Arial, sans-serif;
        font-size: 26px;
        font-stretch: condensed;
        line-height: 30px;
        padding-top: 15px;
        text-align: center;
        text-transform: uppercase;
      }

      .hero-gift {
        color: #ffffff;

        font-family: "Champion HTF Featherweight", "Champion-HTF-Featherweight", Impact, "Arial Narrow", Helvetica, sans-serif;
        font-size: 18px;
        line-height: 22px;
        padding-top: 15px;
        text-align: center;
        text-transform: uppercase;
        transform: scaleY(1.38) scaleX(0.88);
        
      }

      .hero-right-img {
        height: 386px;
        object-fit: cover;
        object-position: left top;
        width: 190px;
      }

      .section-2 {
        background-color: #f4f1e2;
        color: #050505;
        font-family: Helvetica, Arial, sans-serif;
      }

      .section-2-inner {
        padding: 64px 46px 0;
        text-align: center;
      }

      .section-2-greeting {
        color: #050505;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 20px;
        font-weight: 400;
        letter-spacing: 0;
        line-height: 26px;
        text-transform: uppercase;
      }

      .section-2-divider {
        padding-top: 12px;
        text-align: center;
      }

      .section-2-divider img {
        display: inline-block;
        filter: brightness(0) saturate(100%) invert(54%) sepia(93%) saturate(553%) hue-rotate(141deg) brightness(88%) contrast(91%);
        height: auto;
        width: 100px;
      }

      .section-2-copy {
        color: #050505;
        font-family: Helvetica, Arial, sans-serif;
        font-size: 16px;
        line-height: 28px;
        padding-top: 15px;
        text-align: center;
      }

      .mi-red {
        color: #f3282e;
        font-weight: 700;
      }

      .section-2-banner-wrap {
        padding-top: 56px;
        position: relative;
        text-align: center;
      }

      .section-2-banner-frame {
        display: inline-block;
        line-height: 0;
        position: relative;
      }

      .section-2-placeholder {
        background-image: url("https://i.ibb.co/DHQfPXtp/Pattern-Mi-Campo.png");
        background-position: left top;
        background-repeat: repeat;
        background-size: auto;
        font-weight: 700;
        height: 347px;
        overflow: hidden;
        position: absolute;
        left: -112px;
        top: 34px;
        width: 680px;
        z-index: 0;
      }

      .section-2-placeholder-row {
        display: none;
      }

      .section-2-banner-frame:before {
        background-color: transparent;
        content: "";
        height: 0;
        left: -16px;
        position: absolute;
        top: -17px;
        width: 456px;
        z-index: 1;
      }

      .section-2-banner-frame:after {
        background-color: transparent;
        bottom: -17px;
        content: "";
        height: 0;
        position: absolute;
        right: -16px;
        width: 456px;
        z-index: 1;
      }

      .section-2-banner {
        display: block;
        height: auto;
        position: relative;
        width: 456px;
        z-index: 2;
      }

      .section-3 {
        background-color: #f4f1e2;
        color: #171716;
        font-family: Helvetica, Arial, sans-serif;
      }

      .section-3-banner {
        background-color: #f3282e;
        background-image: url("https://i.ibb.co/7JNqRMxS/Section-red.png");
        background-position: center center;
        background-repeat: no-repeat;
        background-size: 100% 100%;
        color: #171716;
        height: 238px;
        overflow: hidden;
        position: relative;
      }

      .section-3-banner:before,
      .section-3-banner:after {
        background-image: url("data:image/svg+xml;base64,");
        background-repeat: no-repeat;
        background-size: 100% 8px;
        content: "";
        height: 8px;
        left: -1px;
        position: absolute;
        width: calc(100% + 2px);
        z-index: 2;
      }

      .section-3-banner:before {
        top: 8px;
        transform: scaleY(-1);
        transform-origin: center;
      }

      .section-3-banner:after {
        bottom: 8px;
      }

      .section-3-texture {
        background-image: repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.06) 0 1px, transparent 1px 7px);
        display: none;
        height: 100%;
        left: 40%;
        opacity: 0.5;
        position: absolute;
        top: 0;
        width: 60%;
      }

      .section-3-card {
        height: 118px;
        left: 34px;
        position: absolute;
        top: 62px;
        width: 142px;
        z-index: 3;
      }

      .section-3-card svg {
        display: block;
        height: 100%;
        overflow: visible;
        width: 100%;
      }

      .section-3-copy-wrap {
        left: 178px;
        position: absolute;
        top: 56px;
        width: 500px;
        z-index: 3;
      }

      .section-3-please {
        color: #171716;
        font-family: "Champion HTF Featherweight", "Champion-HTF-Featherweight", Impact, "Arial Narrow", Helvetica, sans-serif;
        font-size: 36px;
        line-height: 36px;
        text-transform: uppercase;
        transform: scaleY(1.2) scaleX(0.95);
      }

      .section-3-main {
        color: #f4f1e2;
        font-family: "Champion HTF Featherweight", "Champion-HTF-Featherweight", Impact, "Arial Narrow", Helvetica, sans-serif;
        font-size: 36px;
        line-height: 42px;
        text-transform: uppercase;
        transform: scaleY(1.2) scaleX(0.95);
      }

      .section-3-thanks {
        color: #171716;
        font-family: "Champion HTF Featherweight", "Champion-HTF-Featherweight", Impact, "Arial Narrow", Helvetica, sans-serif;
        font-size: 30px;
        line-height: 34px;
        text-transform: uppercase;
        transform: scaleY(1.2) scaleX(0.95);
      }

      .section-4 {
        background-color: #f4f1e2;
        color: #050505;
        font-family: Helvetica, Arial, sans-serif;
      }

      .section-4-inner {
        padding: 44px 0 48px;
        text-align: center;
      }

      .section-4-code {
        border-bottom: 2px solid #4f4f4f;
        border-top: 2px solid #4f4f4f;
        display: inline-block;
        font-size: 16px;
        font-weight: 700;
        line-height: 22px;
        padding: 12px 16px 10px;
        min-width: 360px;
      }

      .section-4-copy {
        font-family: Helvetica, Arial, sans-serif;
        font-size: 16px;
        line-height: 28px;
        margin: 34px auto 0;
        width: 520px;
      }

      .section-4-link {
        color: #050505;
        text-decoration: underline;
      }

      .section-5 {
        background-color: #f4f1e2;
        color: #1697b2;
        font-family: Helvetica, Arial, sans-serif;
      }

      .section-5-image-wrap {
        background-color: #f4f1e2;
      }

      .section-5-image {
        display: block;
        height: auto;
        width: 680px;
      }

      .section-5-friends {
        background-color: #f4f1e2;
        color: #1697b2;
        font-family: Helvetica, Arial, sans-serif;
        padding: 50px 20px 56px;
        text-align: center;
        text-transform: uppercase;
      }

      .section-5-friends-small {
        font-size: 16px;
        font-weight: 700;
        line-height: 20px;
      }

      .section-5-friends-brand {
        font-size: 24px;
        font-weight: 700;
        line-height: 30px;
        padding-top: 4px;
      }

      .mi-footer {
        background-color: #ffffff;
        color: #6d6d6d;
        font-family: Helvetica, Arial, sans-serif;
      }

      .mi-footer-hero {
        display: block;
        height: auto;
        width: 680px;
      }

      .mi-footer-cta {
        color: #ffffff;
        font-size: 22px;
        line-height: 48px;
        text-align: center;
        text-transform: uppercase;
      }

      .mi-footer-visit {
        background-color: #4c92a0;
      }

      .mi-footer-follow {
        background-color: #f3282e;
      }

      .mi-footer-icon {
        display: inline-block;
        height: 22px;
        margin-right: 14px;
        vertical-align: -4px;
        width: 22px;
      }

      .mi-footer-copy {
        color: #6d6d6d;
        font-size: 11px;
        line-height: 16px;
        text-align: center;
      }

      .mi-footer-legal {
        padding: 18px 40px 8px;
      }

      .mi-footer-address {
        padding: 8px 40px 42px;
      }

      .mi-footer-link {
        color: #6d6d6d;
        text-decoration: none;
      }

      @media screen and (max-width: 480px) {
        .mi-container {
          width: 100% !important;
        }

        .section-2-inner {
          padding-left: 22px !important;
          padding-right: 22px !important;
        }

        .section-2-banner,
        .section-2-banner-frame:before,
        .section-2-banner-frame:after {
          width: 100% !important;
        }

        .section-4-copy {
          width: 86% !important;
        }

        .section-5-image {
          width: 100% !important;
        }

        .mi-footer-hero {
          width: 100% !important;
        }
      }
    </style>
  </head>
  <body>
    <table width="100%" border="0" cellspacing="0" cellpadding="0" role="presentation">
      <tr>
        <td align="center" style="padding:12px 0;background-color:#eee9dd;">
          <table class="mi-container" width="680" border="0" cellspacing="0" cellpadding="0" role="presentation">
            %%=CONTENTBLOCKBYNAME("MiCampoBrowserLink")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoHero")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoSection2")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoSection3")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoSection4")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoSection5")=%%
            %%=CONTENTBLOCKBYNAME("MiCampoFooter")=%%
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
