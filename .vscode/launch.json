  "version": "0.2.0",
  "configurations": [
    {
      "name": "AMPscript launch",
      "type": "coreclr",
      "request": "launch",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "program": "${command:ampscript.getWebhostLocation}",
      "args": [
        "ampscript","--source","${file}"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    }



    
    
  ]
}